# AI Orchestrator - Environment Variables
# Copy this file to .env and fill in your values.

# Obsidian Vault Path
ORCH_VAULT_PATH=C:\Users\you\obsidian_vault

# Queue file (optional - defaults to VAULT_PATH/99_System/AI/agent-queue.md)
# ORCH_QUEUE_FILE=

# Telegram Notifications (optional - leave empty to disable)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 429 Token Estimation Settings (defaults: 4, 5, 15000, 100000, 30000)
# ORCH_CHARS_PER_TOKEN=4
# ORCH_OUTPUT_TOKEN_WEIGHT=5
# ORCH_TOKENS_PER_PCT_CLAUDE=15000
# ORCH_TOKENS_PER_PCT_GEMINI=100000
# ORCH_TOKENS_PER_PCT_CODEX=30000
