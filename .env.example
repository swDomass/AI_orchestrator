# AI Orchestrator — Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.

# ── Required ──────────────────────────────────────────────────────────────────
# Path to your Obsidian vault (or any directory containing your queue file)
ORCH_VAULT_PATH=C:\Users\you\obsidian_vault

# ── Queue (optional) ──────────────────────────────────────────────────────────
# Direct path to queue file. Defaults to <ORCH_VAULT_PATH>/99_System/AI/agent-queue.md
# ORCH_QUEUE_FILE=

# ── Security: Allowed Working Directories ─────────────────────────────────────
# Semicolon-separated list of root paths that cwd: tags are validated against.
# Leave unset (or empty) to allow all paths — set it to restrict task execution
# to specific directories only.
# ALLOWED_CWD_ROOTS=C:\projects;D:\work

# ── Telegram (optional) ───────────────────────────────────────────────────────
# Required for Telegram notifications, bot commands, and approval flows.
# Create a bot via @BotFather, then get your chat ID via @userinfobot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Provider Capacity Thresholds ──────────────────────────────────────────────
# Minimum remaining capacity (%) before a provider is considered exhausted.
# MIN_CAPACITY_PERCENT=10

# Per-window thresholds (override MIN_CAPACITY_PERCENT for specific windows):
# CLAUDE_FIVE_HOUR_MIN_CAPACITY_PCT=10
# CLAUDE_SEVEN_DAY_MIN_CAPACITY_PCT=3
# CODEX_PRIMARY_MIN_CAPACITY_PCT=10
# CODEX_SECONDARY_MIN_CAPACITY_PCT=3

# ── Claude HTTP 429 Local Fallback ────────────────────────────────────────────
# Enables reading token usage from local JSONL files instead of the monitoring API
# when cclimits returns HTTP 429. Requires: pip install claude-monitor
# Values: pro | max5 | max20 | custom
# CLAUDE_PLAN=pro

# ── Dashboard ─────────────────────────────────────────────────────────────────
# DASHBOARD_PORT=8411

# ── Telegram Rate Limits ──────────────────────────────────────────────────────
# Max task text length accepted via /task command (characters)
# TELEGRAM_MAX_TASK_LENGTH=500
